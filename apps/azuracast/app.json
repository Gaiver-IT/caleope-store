{
  "id": "azuracast",
  "name": "AzuraCast",
  "category": "media",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [
    { "name": "web",     "container": 80,   "dynamic": true },
    { "name": "sftp",    "container": 2022,  "dynamic": true },
    { "name": "icecast", "container": 8500,  "dynamic": true }
  ],
  "volumes": [
    { "source": "app-data/azuracast/stations", "target": "/var/azuracast/stations" },
    { "source": "app-data/azuracast/geoip",    "target": "/var/azuracast/geoip"    },
    { "source": "app-data/azuracast/backups",   "target": "/var/azuracast/backups"  },
    { "source": "app-data/azuracast/acme",      "target": "/var/azuracast/acme"     }
  ],
  "backup": { "enabled": true }
}
