{
  "id": "linkding",
  "name": "Linkding",
  "category": "productivity",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 9090, "dynamic": true }],
  "volumes": [
    { "source": "app-data/linkding/data", "target": "/etc/linkding/data" }
  ],
  "backup": { "enabled": true }
}
