{
  "id": "filebrowser",
  "name": "File Browser",
  "description": "Gestionnaire de fichiers web avec upload, édition et partage.",
  "category": "utilities",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 80, "dynamic": true }],
  "volumes": [
    { "source": "app-data/filebrowser",      "target": "/srv" },
    { "source": "app-data/filebrowser/db",   "target": "/database" },
    { "source": "app-data/filebrowser/conf", "target": "/config" }
  ],
  "backup": { "enabled": true }
}
