{
  "id": "immich",
  "name": "Immich",
  "category": "media",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 2283, "dynamic": true }],
  "volumes": [
    { "source": "app-data/immich/library", "target": "/usr/src/app/upload", "nas": true },
    { "source": "app-data/immich/db", "target": "/var/lib/postgresql/data" }
  ],
  "backup": { "enabled": true },
  "secure_headers": true
}
