{
  "id": "stirling-pdf",
  "name": "Stirling PDF",
  "category": "productivity",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": false },
  "ports": [{ "name": "web", "container": 8080, "dynamic": true }],
  "volumes": [
    { "source": "app-data/stirling-pdf/configs", "target": "/configs" },
    { "source": "app-data/stirling-pdf/logs",    "target": "/logs" }
  ],
  "backup": { "enabled": false }
}
