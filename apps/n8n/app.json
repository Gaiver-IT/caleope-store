{
  "id": "n8n",
  "name": "n8n",
  "description": "Plateforme d'automatisation de workflows, alternative à Zapier.",
  "category": "automation",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 5678, "dynamic": true }],
  "volumes": [
    { "source": "app-data/n8n/data", "target": "/home/node/.n8n" }
  ],
  "backup": { "enabled": true }
}
