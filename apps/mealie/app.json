{
  "id": "mealie",
  "name": "Mealie",
  "description": "Gestionnaire de recettes self-hosted avec import automatique depuis URLs.",
  "category": "lifestyle",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 9000, "dynamic": true }],
  "volumes": [
    { "source": "app-data/mealie/data", "target": "/app/data" }
  ],
  "backup": { "enabled": true }
}
