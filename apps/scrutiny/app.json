{
  "id": "scrutiny",
  "name": "Scrutiny",
  "description": "Monitoring de santé des disques durs via S.M.A.R.T. — alertes et historique.",
  "category": "monitoring",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": true
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 8080, "dynamic": true }],
  "volumes": [
    { "source": "app-data/scrutiny/config", "target": "/opt/scrutiny/config" },
    { "source": "app-data/scrutiny/influxdb", "target": "/opt/scrutiny/influxdb" }
  ],
  "backup": { "enabled": true }
}
