{
  "id": "code-server",
  "name": "Code Server",
  "description": "VS Code dans le navigateur — éditeur de code complet accessible depuis n'importe où.",
  "category": "dev",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": true },
  "ports": [{ "name": "web", "container": 8080, "dynamic": true }],
  "volumes": [
    { "source": "app-data/code-server/config", "target": "/config" },
    { "source": "app-data/code-server/workspace", "target": "/workspace" }
  ],
  "backup": { "enabled": true }
}
