{
  "id": "vaultwarden",
  "name": "Vaultwarden",
  "category": "security",
  "channel": "stable",
  "repository": "official",
  "capabilities": {
    "reverse_proxy": true,
    "gpu": false,
    "docker_socket": false,
    "privileged": false
  },
  "network": { "public": true, "internal": false },
  "ports": [{ "name": "web", "container": 80, "dynamic": true }],
  "volumes": [
    { "source": "app-data/vaultwarden/data", "target": "/data" }
  ],
  "backup": { "enabled": true },
  "secure_headers": true
}
